{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build active C++ file",
            "type": "shell",
            "command": "clang++",
            "args": [
                "-std=c++20",
                "${file}",
                "-o",
                "${fileDirname}/main"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}